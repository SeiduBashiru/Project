
import sqlite3

def init_db():
    conn = sqlite3.connect("threat_intel.db")
    cursor = conn.cursor()

    cursor.execute("""
    CREATE TABLE IF NOT EXISTS indicators (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        type TEXT,
        value TEXT UNIQUE,
        threat_level TEXT,
        source TEXT
    )
    """)

    conn.commit()
    conn.close()

init_db()
