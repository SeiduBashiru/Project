3. Dynamic Security Policy Enforcer (Python)
import json
from datetime import datetime

class PolicyEnforcer:

    def __init__(self, policy_file):
        with open(policy_file) as f:
            self.policies = json.load(f)["policies"]

    def evaluate(self, request):
        for policy in self.policies:

            if (policy["role"] == request["role"] and
                policy["resource"] == request["resource"] and
                policy["action"] == request["action"]):

                conditions = policy.get("conditions", {})

                if self.check_conditions(conditions, request):
                    return "ACCESS GRANTED"

        return "ACCESS DENIED"

    def check_conditions(self, conditions, request):

        for key, value in conditions.items():

            if key not in request:
                return False

            if request[key] != value:
                return False

        return True


