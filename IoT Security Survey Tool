
import nmap
import socket

scanner = nmap.PortScanner()

network = input("Enter network range (example: 192.168.1.0/24): ")

print("\nScanning network for IoT devices...\n")

scanner.scan(hosts=network, arguments="-sS -O")

iot_ports = [21, 22, 23, 80, 443, 1883, 5683]  
# Common IoT service ports

def identify_device(host):

    try:
        hostname = socket.gethostbyaddr(host)[0]
    except:
        hostname = "Unknown"

    return hostname


def security_analysis(open_ports):

    risks = []

    if 23 in open_ports:
        risks.append("Telnet open (very insecure)")

    if 21 in open_ports:
        risks.append("FTP service exposed")

    if 80 in open_ports:
        risks.append("Web interface detected")

    if 1883 in open_ports:
        risks.append("MQTT service (IoT messaging)")

    if 5683 in open_ports:
        risks.append("CoAP protocol detected")

    return risks


for host in scanner.all_hosts():

    print("------------------------------------------------")

    hostname = identify_device(host)
    print("Device IP:", host)
    print("Hostname:", hostname)

    open_ports = []

    for proto in scanner[host].all_protocols():

        ports = scanner[host][proto].keys()

        for port in ports:

            if scanner[host][proto][port]['state'] == 'open':
                open_ports.append(port)

    print("Open Ports:", open_ports)

    risks = security_analysis(open_ports)

    if risks:
        print("Security Risks:")
        for r in risks:
            print("-", r)
    else:
        print("No major risks detected")

print("\nIoT Security Survey Completed.")
