
import os
import json
from cryptography.fernet import Fernet

KEY_STORE = "keystore.json"


class KeyManagementSystem:

    def __init__(self):
        if not os.path.exists(KEY_STORE):
            with open(KEY_STORE, "w") as f:
                json.dump({}, f)

        with open(KEY_STORE, "r") as f:
            self.keys = json.load(f)

    def save_keys(self):
        with open(KEY_STORE, "w") as f:
            json.dump(self.keys, f)

    def generate_key(self, key_name):
        key = Fernet.generate_key().decode()
        self.keys[key_name] = key
        self.save_keys()
        print(f"Key '{key_name}' generated.")

    def get_cipher(self, key_name):
        key = self.keys.get(key_name)

        if not key:
            raise Exception("Key not found!")

        return Fernet(key.encode())

    def encrypt(self, key_name, data):

        cipher = self.get_cipher(key_name)
        encrypted = cipher.encrypt(data.encode())

        return encrypted.decode()

    def decrypt(self, key_name, encrypted_data):

        cipher = self.get_cipher(key_name)
        decrypted = cipher.decrypt(encrypted_data.encode())

        return decrypted.decode()

    def rotate_key(self, key_name):

        if key_name not in self.keys:
            print("Key not found")
            return

        new_key = Fernet.generate_key().decode()
        self.keys[key_name] = new_key
        self.save_keys()

        print(f"Key '{key_name}' rotated successfully.")


# ------------------------
# Example Usage
# ------------------------

kms = KeyManagementSystem()

# Generate key
kms.generate_key("database_key")

# Encrypt data
secret = "Sensitive Password"
encrypted = kms.encrypt("database_key", secret)

print("Encrypted:", encrypted)

# Decrypt data
decrypted = kms.decrypt("database_key", encrypted)

print("Decrypted:", decrypted)

# Rotate key
kms.rotate_key("database_key")
