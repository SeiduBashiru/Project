2. Enrollment (Register User Face)
import face_recognition
import cv2
import pickle

# Start webcam
video_capture = cv2.VideoCapture(0)

print("Look at the camera to register...")

ret, frame = video_capture.read()

# Detect face
face_locations = face_recognition.face_locations(frame)

if len(face_locations) > 0:
    face_encoding = face_recognition.face_encodings(frame, face_locations)[0]

    # Save encoding
    with open("user_face.pkl", "wb") as f:
        pickle.dump(face_encoding, f)

    print("User face registered successfully!")

else:
    print("No face detected.")

video_capture.release()
cv2.destroyAllWindows()
3. Authentication (Login with Face)
import face_recognition
import cv2
import pickle
import numpy as np

# Load registered face
with open("user_face.pkl", "rb") as f:
    known_face_encoding = pickle.load(f)

video_capture = cv2.VideoCapture(0)

print("Authenticating...")

while True:
    ret, frame = video_capture.read()

    face_locations = face_recognition.face_locations(frame)
    face_encodings = face_recognition.face_encodings(frame, face_locations)

    for face_encoding in face_encodings:
        match = face_recognition.compare_faces([known_face_encoding], face_encoding)

        if match[0]:
            print("Authentication Successful!")
            video_capture.release()
            cv2.destroyAllWindows()
            exit()

        else:
            print("Authentication Failed!")

    cv2.im.show("Biometric Authentication", frame)

    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

video_capture.release()
cv2.destroyAllWindows()
