
from scapy.all import *
from collections import defaultdict

networks = defaultdict(dict)

def analyze_wifi(packet):

    if packet.haslayer(Dot11Beacon):

        bssid = packet[Dot11].addr2
        ssid = packet[Dot11Elt].info.decode(errors="ignore")
        signal = packet.dBm_AntSignal if hasattr(packet, "dBm_AntSignal") else "N/A"

        stats = packet[Dot11Beacon].network_stats()
        security = stats.get("crypto")

        networks[bssid]["SSID"] = ssid
        networks[bssid]["Signal"] = signal
        networks[bssid]["Security"] = security

        print_networks()

def print_networks():

    print("\nDetected Wi-Fi Networks")
    print("-" * 60)

    for bssid, data in networks.items():

        ssid = data.get("SSID", "")
        signal = data.get("Signal", "")
        security = ",".join(data.get("Security", []))

        risk = analyze_security(security)

        print(f"SSID: {ssid}")
        print(f"BSSID: {bssid}")
        print(f"Signal: {signal}")
        print(f"Security: {security}")
        print(f"Risk Level: {risk}")
        print("-" * 60)

def analyze_security(security):

    if "WPA3" in security:
        return "Very Secure"

    if "WPA2" in security:
        return "Secure"

    if "WPA" in security:
        return "Moderate"

    if "WEP" in security:
        return "High Risk (WEP vulnerable)"

    if security == "":
        return "Open Network (Dangerous)"

    return "Unknown"


print("Starting Wi-Fi Security Analyzer...")

sniff(iface="wlan0mon", prn=analyze_wifi, store=0)
